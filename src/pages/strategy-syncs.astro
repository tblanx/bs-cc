---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Strategy Syncs"
  description="Build momentum with Clare or Tony — ad-hoc or weekly connects for KPI alignment, prioritization, and planning."
>

  <!-- Hero -->
  <section class="max-w-6xl mx-auto px-6 pt-20 pb-16">
    <div class="w-12 h-px bg-warm mb-8"></div>
    <p class="text-xs tracking-widest uppercase text-warm font-medium mb-4">Strategy Syncs</p>
    <h1 class="text-5xl md:text-6xl font-extralight leading-tight tracking-tight mb-8 max-w-2xl">
      Build momentum<br />with Clare or Tony.
    </h1>
    <p class="text-lg text-grey-dark font-light max-w-md leading-relaxed">
      A direct line to senior thinking — when you need alignment, a sounding board,
      or a push in the right direction.
    </p>
  </section>

  <!-- What it is -->
  <section class="max-w-6xl mx-auto px-6 pb-20">
    <div class="grid md:grid-cols-3 gap-px bg-grey-light">

      <div class="bg-paper p-10">
        <p class="text-xs tracking-widest uppercase text-grey font-medium mb-4">Format</p>
        <h3 class="text-xl font-light mb-3">Ad-hoc or Weekly Connects</h3>
        <p class="text-grey-dark font-light text-sm leading-relaxed">
          Meet when you need it, or establish a regular cadence. Flexible to where
          you are and what the moment calls for.
        </p>
      </div>

      <div class="bg-paper p-10">
        <p class="text-xs tracking-widest uppercase text-grey font-medium mb-4">Focus</p>
        <h3 class="text-xl font-light mb-3">Align on Core KPIs</h3>
        <p class="text-grey-dark font-light text-sm leading-relaxed">
          Review what's moving, what's not, and what it means. Keep your most
          important metrics front and center.
        </p>
      </div>

      <div class="bg-paper p-10">
        <p class="text-xs tracking-widest uppercase text-grey font-medium mb-4">Outcome</p>
        <h3 class="text-xl font-light mb-3">Prioritization & Planning</h3>
        <p class="text-grey-dark font-light text-sm leading-relaxed">
          Leave every session with clarity on what to do next and why. Less noise,
          more momentum.
        </p>
      </div>

    </div>
  </section>

  <!-- Who it's for -->
  <section class="bg-ink text-paper">
    <div class="max-w-6xl mx-auto px-6 py-16">
      <p class="text-xs tracking-widest uppercase text-grey font-medium mb-10">Works for both paths</p>
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <div class="w-8 h-px bg-warm mb-5"></div>
          <h3 class="text-lg font-light mb-3 text-warm">For Good</h3>
          <p class="text-grey font-light text-sm leading-relaxed">
            Nonprofits, foundations, and family offices working through strategy,
            impact priorities, and organizational decisions.
          </p>
        </div>
        <div>
          <div class="w-8 h-px bg-paper mb-5"></div>
          <h3 class="text-lg font-light mb-3">For Business</h3>
          <p class="text-grey font-light text-sm leading-relaxed">
            Founders, operators, and executives navigating growth, revenue,
            and execution challenges.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-6xl mx-auto px-6 py-16">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
      <div>
        <h2 class="text-3xl font-extralight mb-3">Ready to sync?</h2>
        <p class="text-grey-dark font-light">Reach out and we'll find a time.</p>
      </div>
      <a
        href="/contact"
        class="bg-warm text-white px-8 py-4 text-sm font-medium tracking-wide hover:bg-warm/90 transition-colors whitespace-nowrap"
      >
        Get in touch →
      </a>
    </div>
  </section>

</Layout>
