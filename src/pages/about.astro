---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About" description="About blankspace — a full-spectrum strategy and execution firm.">

  <section class="max-w-6xl mx-auto px-6 pt-20 pb-16">
    <div class="w-12 h-px bg-grey mb-8"></div>
    <p class="text-xs tracking-widest uppercase text-grey font-medium mb-4">About</p>
    <h1 class="text-5xl md:text-6xl font-extralight leading-tight tracking-tight mb-8 max-w-2xl">
      We do the work<br />that matters.
    </h1>
    <p class="text-lg text-grey-dark font-light max-w-xl leading-relaxed">
      blankspace is a consulting firm built on the belief that rigorous strategy
      and genuine commitment to execution can drive change — whether in a boardroom
      or a community.
    </p>
  </section>

  <section class="max-w-6xl mx-auto px-6 pb-20">
    <div class="grid md:grid-cols-2 gap-16 max-w-4xl">
      <div>
        <div class="w-8 h-px bg-warm mb-6"></div>
        <h2 class="text-xl font-light mb-4">For Good</h2>
        <p class="text-grey-dark font-light leading-relaxed text-sm">
          Our impact practice works at the intersection of philanthropy and
          organizational effectiveness. We help family offices, foundations,
          and nonprofits build the strategy and structures for lasting change.
        </p>
      </div>
      <div>
        <div class="w-8 h-px bg-ink mb-6"></div>
        <h2 class="text-xl font-light mb-4">For Business</h2>
        <p class="text-grey-dark font-light leading-relaxed text-sm">
          Our business practice brings full-spectrum capability to companies at
          every stage — from early-stage strategy to enterprise transformation,
          revenue operations, and growth execution.
        </p>
      </div>
    </div>
  </section>

</Layout>
