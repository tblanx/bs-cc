---
import Layout from "../../layouts/Layout.astro";
import LogoWall from "../../components/LogoWall.astro";
---

<Layout title="Our Work" description="blankspace client work across business consulting and philanthropic impact.">

  <section class="max-w-6xl mx-auto px-6 pt-20 pb-16">
    <div class="w-12 h-px bg-grey mb-8"></div>
    <p class="text-xs tracking-widest uppercase text-grey font-medium mb-4">Our Work</p>
    <h1 class="text-5xl md:text-6xl font-extralight leading-tight tracking-tight mb-8 max-w-2xl">
      Proof in the work.
    </h1>
    <p class="text-lg text-grey-dark font-light max-w-xl leading-relaxed">
      We've partnered with organizations across sectors — from Fortune 500 companies
      to early-stage nonprofits — to deliver strategy, execution, and lasting results.
    </p>
  </section>

  <!-- Logo wall -->
  <section>
    <div class="max-w-6xl mx-auto px-6 pt-4 pb-6">
      <p class="text-xs tracking-widest uppercase text-grey font-medium mb-10">Organizations we've served</p>
    </div>
    <LogoWall />
  </section>

  <!-- Case studies placeholder -->
  <section class="bg-grey-light/40">
    <div class="max-w-6xl mx-auto px-6 py-16">
      <p class="text-xs tracking-widest uppercase text-grey font-medium mb-4">Case Studies</p>
      <p class="text-grey-dark font-light">Detailed case studies coming soon.</p>
    </div>
  </section>

</Layout>
