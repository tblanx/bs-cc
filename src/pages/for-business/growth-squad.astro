---
import Layout from "../../layouts/Layout.astro";

const process = [
  {
    step: "01",
    name: "Form & Align",
    desc: "Build the squad with shared goals, clear roles, and collective ownership from day one.",
  },
  {
    step: "02",
    name: "Weekly Sprint Planning",
    desc: "30-minute strategy sessions focused on top accounts, priorities, and the week ahead.",
  },
  {
    step: "03",
    name: "Daily Standups",
    desc: "15-minute check-ins to move priority accounts forward and remove blockers fast.",
  },
  {
    step: "04",
    name: "Measure & Iterate",
    desc: "Track what's working, run retrospectives, and sharpen the model every sprint.",
  },
];

const roles = [
  { title: "Sales / Business Development", desc: "Driving pipeline and closing opportunities" },
  { title: "Marketing", desc: "Content creation, campaign execution, and sales enablement" },
  { title: "Growth Lead", desc: "Data, strategy, and cross-squad coordination" },
  { title: "Customer Success", desc: "Account intelligence and expansion signals" },
  { title: "Partnerships", desc: "Ecosystem leverage and channel development" },
  { title: "Sales Leadership", desc: "Strategic guidance and blocker removal" },
];

const metrics = [
  { stat: "↑40%", label: "Lead Quality" },
  { stat: "↑25%", label: "Conversion Rates" },
  { stat: "↓30%", label: "Sales Cycle Length" },
  { stat: "↑60%", label: "Team Alignment" },
];
---

<Layout
  title="Growth Squad"
  description="blankspace Growth Squad — an agile cross-functional revenue team model for marketing, sales, and customer success."
>

  <!-- Hero -->
  <section class="max-w-6xl mx-auto px-6 pt-20 pb-16">
    <div class="w-12 h-px bg-ink mb-8"></div>
    <p class="text-xs tracking-widest uppercase text-grey font-medium mb-4">For Business — Growth Squad</p>
    <h1 class="text-5xl md:text-6xl font-extralight leading-tight tracking-tight mb-8 max-w-2xl">
      Stop paying<br />the silo tax.
    </h1>
    <p class="text-lg text-grey-dark font-light max-w-xl leading-relaxed">
      Handoffs between departments cost deals. Siloed thinking creates accountability gaps.
      Growth Squad applies agile principles to your revenue team — so marketing, sales,
      and success finally move together.
    </p>
  </section>

  <!-- Metrics bar -->
  <section class="bg-ink text-paper">
    <div class="max-w-6xl mx-auto px-6 py-12">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {metrics.map(m => (
          <div>
            <p class="text-3xl font-extralight mb-1">{m.stat}</p>
            <p class="text-xs tracking-widest uppercase text-grey font-medium">{m.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="max-w-6xl mx-auto px-6 py-20">
    <p class="text-xs tracking-widest uppercase text-grey font-medium mb-10">The process</p>
    <div class="grid md:grid-cols-2 gap-px bg-grey-light">
      {process.map(p => (
        <div class="bg-paper p-10">
          <span class="text-xs text-grey font-light tabular-nums">{p.step}</span>
          <h3 class="text-xl font-light mt-2 mb-3">{p.name}</h3>
          <p class="text-grey-dark font-light text-sm leading-relaxed">{p.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Squad roles -->
  <section class="max-w-6xl mx-auto px-6 pb-20">
    <p class="text-xs tracking-widest uppercase text-grey font-medium mb-10">Who's in the squad</p>
    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-px bg-grey-light">
      {roles.map(role => (
        <div class="bg-paper p-8">
          <h4 class="text-sm font-medium mb-2">{role.title}</h4>
          <p class="text-grey font-light text-sm">{role.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Strategy Syncs callout -->
  <section class="bg-grey-light/40">
    <div class="max-w-6xl mx-auto px-6 py-14 flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
      <div>
        <p class="text-xs tracking-widest uppercase text-grey font-medium mb-3">Also available</p>
        <h2 class="text-2xl font-light mb-2">Strategy Syncs</h2>
        <p class="text-grey-dark font-light text-sm max-w-md leading-relaxed">
          Ad-hoc or weekly connects with Tony — to align on KPIs, work through
          decisions, and keep the squad moving.
        </p>
      </div>
      <a
        href="/strategy-syncs"
        class="border border-ink text-ink px-7 py-3 text-sm font-medium tracking-wide hover:bg-ink hover:text-paper transition-colors whitespace-nowrap"
      >
        Learn more →
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-6xl mx-auto px-6 py-16">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
      <div>
        <h2 class="text-3xl font-extralight mb-3">Ready to build your squad?</h2>
        <p class="text-grey-dark font-light">Book a free consultation and let's get to work.</p>
      </div>
      <a
        href="/contact"
        class="bg-ink text-paper px-8 py-4 text-sm font-medium tracking-wide hover:bg-grey-dark transition-colors whitespace-nowrap"
      >
        Book a consultation →
      </a>
    </div>
  </section>

</Layout>
