---
import Layout from "../../layouts/Layout.astro";

const services = [
  {
    name: "Go-To-Market Audit",
    tagline: "Comprehensive analysis of your GTM approach with actionable recommendations.",
    components: [
      "Operating model review",
      "GTM strategy assessment",
      "Team design evaluation",
      "CRM audit",
      "Data and reporting analysis",
    ],
  },
  {
    name: "CRM Implementation",
    tagline: "End-to-end CRM builds focused on team adoption and lasting system value.",
    components: [
      "Business process review",
      "Detailed scope definition",
      "Transparent build phase",
      "Team training",
      "User documentation",
    ],
  },
  {
    name: "Executive RevOps Advisory",
    tagline: "Executive-level RevOps expertise with direct access to your team.",
    components: [
      "Executive-level RevOps advisor",
      "Direct access via Slack",
      "Strategic guidance",
      "Performance optimization",
      "Ongoing support",
    ],
  },
];
---

<Layout
  title="RevOps"
  description="blankspace RevOps — built for reality. GTM audits, CRM implementations, and executive advisory."
>

  <!-- Hero -->
  <section class="max-w-6xl mx-auto px-6 pt-20 pb-16">
    <div class="w-12 h-px bg-ink mb-8"></div>
    <p class="text-xs tracking-widest uppercase text-grey font-medium mb-4">For Business — RevOps</p>
    <h1 class="text-5xl md:text-6xl font-extralight leading-tight tracking-tight mb-8 max-w-2xl">
      RevOps built<br />for reality.
    </h1>
    <p class="text-lg text-grey-dark font-light max-w-xl leading-relaxed">
      Your cross-functional teams need alignment, not more chaos. We bridge the gap
      between sales, marketing, and success — turning fragmented processes into
      revenue-generating machines.
    </p>
  </section>

  <!-- Services -->
  <section class="max-w-6xl mx-auto px-6 pb-20">
    <p class="text-xs tracking-widest uppercase text-grey font-medium mb-10">What we do</p>
    <div class="flex flex-col gap-px bg-grey-light">
      {services.map((service, i) => (
        <div class="bg-paper p-10 grid md:grid-cols-2 gap-10">
          <div>
            <span class="text-xs text-grey font-light tabular-nums">0{i + 1}</span>
            <h3 class="text-2xl font-light mt-2 mb-3">{service.name}</h3>
            <p class="text-grey-dark font-light text-sm leading-relaxed">{service.tagline}</p>
          </div>
          <ul class="flex flex-col gap-2 justify-center">
            {service.components.map(c => (
              <li class="flex gap-3 text-sm font-light text-grey-dark">
                <span class="text-grey mt-0.5 shrink-0">—</span>
                <span>{c}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- Strategy Syncs callout -->
  <section class="bg-grey-light/40">
    <div class="max-w-6xl mx-auto px-6 py-14 flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
      <div>
        <p class="text-xs tracking-widest uppercase text-grey font-medium mb-3">Also available</p>
        <h2 class="text-2xl font-light mb-2">Strategy Syncs</h2>
        <p class="text-grey-dark font-light text-sm max-w-md leading-relaxed">
          Ad-hoc or weekly connects with Tony — to align on KPIs, work through
          decisions, and keep momentum going.
        </p>
      </div>
      <a
        href="/strategy-syncs"
        class="border border-ink text-ink px-7 py-3 text-sm font-medium tracking-wide hover:bg-ink hover:text-paper transition-colors whitespace-nowrap"
      >
        Learn more →
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-6xl mx-auto px-6 py-16">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
      <div>
        <h2 class="text-3xl font-extralight mb-3">Ready to get aligned?</h2>
        <p class="text-grey-dark font-light">Tell us where your revenue engine is breaking down.</p>
      </div>
      <a
        href="/contact"
        class="bg-ink text-paper px-8 py-4 text-sm font-medium tracking-wide hover:bg-grey-dark transition-colors whitespace-nowrap"
      >
        Start a conversation →
      </a>
    </div>
  </section>

</Layout>
