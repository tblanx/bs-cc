---
import Wordmark from "./Wordmark.astro";
---

<footer class="border-t border-grey-light mt-24">
  <div class="max-w-6xl mx-auto px-6 py-12 flex flex-col md:flex-row items-start md:items-center justify-between gap-8">

    <div class="flex flex-col gap-3">
      <Wordmark height={20} />
      <p class="text-xs text-grey font-light tracking-wide">
        Full-spectrum strategy &amp; execution.
      </p>
    </div>

    <nav class="flex flex-col md:flex-row gap-4 md:gap-8 text-xs text-grey font-light tracking-wide">
      <a href="/for-good" class="text-warm hover:text-warm/70 transition-colors">For Good</a>
      <a href="/for-business" class="hover:text-ink transition-colors">For Business</a>
      <a href="/our-work" class="hover:text-ink transition-colors">Our Work</a>
      <a href="/about" class="hover:text-ink transition-colors">About</a>
      <a href="/contact" class="hover:text-ink transition-colors">Contact</a>
    </nav>

    <p class="text-xs text-grey font-light">
      © {new Date().getFullYear()} blankspace
    </p>
  </div>
</footer>
