---
interface Props {
  size?: number;
  class?: string;
}
const { size = 120, class: className = "" } = Astro.props;
// viewBox is 100 wide × 118 tall to accommodate "space" hanging below the square
const height = Math.round(size * 1.04);
---

<svg
  width={size}
  height={height}
  viewBox="0 0 100 103"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-label="blankspace"
>
  <!-- Perfect rounded square: 80×80, centered horizontally, top margin 5 -->
  <rect x="10" y="5" width="80" height="80" rx="8" ry="8" fill="#9B9B9B" />

  <!-- "blank" — white, bottom-left inside the square (rect bottom at y=85) -->
  <text
    x="16"
    y="81"
    font-family="'Open Sans', system-ui, sans-serif"
    font-weight="400"
    font-size="15"
    fill="white"
    letter-spacing="-0.2"
  >blank</text>

  <!-- "space" — grey, left-aligned with "blank", below the square -->
  <text
    x="16"
    y="95"
    font-family="'Open Sans', system-ui, sans-serif"
    font-weight="400"
    font-size="15"
    fill="#9B9B9B"
    letter-spacing="-0.2"
  >space</text>
</svg>
